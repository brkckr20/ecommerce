  <Name>Mağaza &amp; E-Ticaret Stok Listesi</Name>
  <Explanation>26.03.2026 - bc</Explanation>
  <MenuLocation>InventoryMenu\Özel Raporlar\E-Ticaret</MenuLocation>
  <OpenCmdListName />
  <OptionsList />
  <RolePrivilege />
  <SqlScript>SELECT 
    I.InventoryCode [Ürün Kodu],
    I.InventoryName [Ürün Adı],
    I.SeasonCode [Sezon],
    IB.Barcode [Barkod],
    SUM(
        CASE 
            WHEN R.InWarehouseId = 79 THEN RI.Quantity
            WHEN R.OutWarehouseId = 79 THEN -RI.Quantity
            ELSE 0
        END
    ) AS [M36 Mağaza Stok],
    SUM(
        CASE 
            WHEN R.InWarehouseId = 80 THEN RI.Quantity
            WHEN R.OutWarehouseId = 80 THEN -RI.Quantity
            ELSE 0
        END
    ) AS [M37 Fabrika Stok],
    SUM(
        CASE 
            WHEN R.InWarehouseId = 79 THEN RI.Quantity
            WHEN R.OutWarehouseId = 79 THEN -RI.Quantity
            ELSE 0
        END
    ) + SUM(
        CASE 
            WHEN R.InWarehouseId = 80 THEN RI.Quantity
            WHEN R.OutWarehouseId = 80 THEN -RI.Quantity
            ELSE 0
        END
    ) [M36 &amp; M37 Toplam Stok],
ISNULL(IPL.Price,0) [Birim Fiyat]
FROM IM_Receipt R
JOIN IM_ReceiptItem RI ON R.RecId = RI.InventoryReceiptId
JOIN IM_Item I ON I.RecId = RI.InventoryId
left join IM_ItemBarcode IB on IB.InventoryId = I.RecId
left join IM_ItemPriceList IPL on I.RecId = IPL.InventoryId and IPL.PriceCode = 'PSF'

where I.SeasonCode in ('Ulus Mağaza', 'Ulus Mağaza S.A.', 'Ulus Mağaza Yaz', 'Ulus Mağaza Arşiv')
and I.InUse != 0

IM_Item_SQLPLACEHOLDER_I
GROUP BY
    I.InventoryCode,
    I.InventoryName,
    IB.Barcode,
    ISNULL(IPL.Price,0),
    I.SeasonCode

order by I.InventoryName
</SqlScript>
